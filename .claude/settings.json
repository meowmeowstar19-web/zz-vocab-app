{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-word-data-xlsx.py\"",
            "statusMessage": "Guarding word-data/*.xlsx"
          }
        ]
      }
    ]
  }
}
